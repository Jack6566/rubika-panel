# ===== Telegram API credentials (from https://my.telegram.org) =====
API_ID=
API_HASH=

# ===== Panel bot token (from @BotFather) =====
BOT_TOKEN=

# ===== Your numeric Telegram ID (from @userinfobot) =====
OWNER_ID=

# ===== Extra admins (optional). Numeric IDs separated by comma, e.g. 111,222 =====
ADMIN_IDS=

# ===== Log group ID (negative number, e.g. -1001234567890) =====
LOG_GROUP_ID=

# ===== Delay between each message in seconds =====
SEND_DELAY=0.5
