# ===== Telegram API credentials (from https://my.telegram.org) =====
API_ID=
API_HASH=

# ===== Panel bot token (from @BotFather) =====
BOT_TOKEN=

# ===== Your numeric Telegram ID (from @userinfobot) =====
OWNER_ID=

# ===== Extra admins (optional). Numeric IDs separated by comma, e.g. 111,222 =====
ADMIN_IDS=

# ===== Log group ID (negative number, e.g. -1001234567890) =====
LOG_GROUP_ID=

# ===== Delay between each message in seconds =====
SEND_DELAY=0.5

# ===== Delay between FORWARDS (Rubika limits forwards harder; keep this higher) =====
FORWARD_DELAY=4

# ===== How long to wait (seconds) when Rubika says TOO_REQUESTS, then resume =====
RATE_LIMIT_WAIT=45

# ===== Forward marker (optional) =====
# Put a file in your Rubika "Saved Messages" and END its caption with this
# marker, e.g.  ...your caption [کد135]
# The bot will find that message and FORWARD it to all recipients (fast, no
# re-upload). Leave empty to use the normal "set content in the panel" flow.
FORWARD_MARKER=


# ===== Optional proxy for the Rubika connection (helps if server IP is blocked) =====
# Examples:
#   PROXY=socks5://1.2.3.4:1080
#   PROXY=socks5://user:pass@1.2.3.4:1080
# Leave empty to connect directly.
PROXY=
